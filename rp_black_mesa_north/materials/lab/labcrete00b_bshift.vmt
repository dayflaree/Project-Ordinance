
LightmappedGeneric
{
	$basetexture "lab/labcrete00b_bshift"
	$bumpmap "lab/labcrete00b_bshift_normal"
	$surfaceprop Concrete

	$detail "detail/bm_cinderblock_detail_01"
	$detailblendfactor 0.9
	
	"$SPECULARGLOSS" "50"
	"$SPECULARCOLOR" "[1 1 1]"

	$envmap "env_cubemap"
	$normalmapalphaenvmapmask 1
	$envmaptint "[0.30 0.30 0.30]"
	$envmapsaturation 0.3
	//$envmapmask "lab/alpha_fade"

	%keywords "bshift , rimas"
}
